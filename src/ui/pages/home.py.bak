"""
src/ui/pages/home.py - ホームダッシュボード
"""
from __future__ import annotations
import streamlit as st


def _load_db_stats() -> dict:
    stats = {
        "total_cases"   : 0,
        "latest_value"  : None,
        "avg_volatility": None,
        "last_eval_date": None,
        "recent_cases"  : [],
    }
    try:
        from src.data.database import get_db_manager
        from src.data.models import ValuationCase, ValuationResult, ValuationParameter
        from sqlalchemy import func, desc

        db = get_db_manager()
        session = db.SessionLocal()
        try:
            stats["total_cases"] = session.query(
                func.count(ValuationCase.id)
            ).scalar() or 0

            recent = (
                session.query(ValuationCase)
                .filter(ValuationCase.is_active == True)
                .order_by(desc(ValuationCase.created_at))
                .limit(5)
                .all()
            )
            stats["recent_cases"] = [
                {
                    "id"        : c.id,
                    "name"      : c.name,
                    "company"   : c.company,
                    "created_at": c.created_at,
                }
                for c in recent
            ]
            if recent:
                stats["last_eval_date"] = recent[0].created_at

            latest_result = (
                session.query(ValuationResult)
                .order_by(desc(ValuationResult.id))
                .first()
            )
            if latest_result:
                stats["latest_value"] = latest_result.option_price

            avg_vol = session.query(
                func.avg(ValuationParameter.volatility)
            ).scalar()
            if avg_vol:
                stats["avg_volatility"] = float(avg_vol) * 100
        finally:
            session.close()
    except Exception:
        pass
    return stats


def render() -> None:
    st.markdown(
        """
        <div style="
            background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%);
            padding: 2.5rem 2rem 2rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
        ">
            <h1 style="color:white; margin:0; font-size:2rem; font-weight:700;">
                ⚖️ Option Valuation System
            </h1>
            <p style="color:#a8d4f5; margin:0.5rem 0 0; font-size:1rem;">
                未上場企業向け　ストックオプション公正価値算定プラットフォーム
            </p>
        </div>
        """,
        unsafe_allow_html=True,
    )

    stats = _load_db_stats()

    c1, c2, c3, c4 = st.columns(4)
    with c1:
        st.metric("📁 評価ケース数", f"{stats['total_cases']} 件")
    with c2:
        val = f"¥{stats['latest_value']:,.1f}" if stats["latest_value"] else "－"
        st.metric("💴 直近オプション価値", val)
    with c3:
        vol = f"{stats['avg_volatility']:.1f} %" if stats["avg_volatility"] else "－"
        st.metric("📉 平均ボラティリティ", vol)
    with c4:
        dt = stats["last_eval_date"].strftime("%Y/%m/%d") if stats["last_eval_date"] else "－"
        st.metric("🕐 最終評価日", dt)

    st.divider()
    st.subheader("🚀 クイックアクション")
    qa1, qa2, qa3 = st.columns(3)

    with qa1:
        if st.button("➕ 新規評価を開始", use_container_width=True, type="primary"):
            st.session_state["current_page"] = "➕ 新規評価"
            st.rerun()
    with qa2:
        if st.button("📁 ケース一覧を見る", use_container_width=True):
            st.session_state["current_page"] = "📁 ケース一覧"
            st.rerun()
    with qa3:
        if st.button("⚙️ 設定", use_container_width=True):
            st.session_state["current_page"] = "⚙️ 設定"
            st.rerun()

    st.divider()
    left_col, right_col = st.columns([3, 2], gap="large")

    with left_col:
        st.subheader("📂 最近の評価ケース")
        if not stats["recent_cases"]:
            st.info("まだ評価ケースがありません。「新規評価」から始めましょう。")
        else:
            for case in stats["recent_cases"]:
                col_a, col_b, col_c = st.columns([4, 2, 1])
                with col_a:
                    st.write(f"**{case['name']}**")
                    st.caption(case["company"])
                with col_b:
                    dt_str = case["created_at"].strftime("%Y/%m/%d") if case["created_at"] else "－"
                    st.caption(dt_str)
                with col_c:
                    if st.button("→", key=f"goto_{case['id']}"):
                        st.session_state["selected_case_id"] = case["id"]
                        st.session_state["current_page"] = "📁 ケース一覧"
                        st.rerun()
                st.divider()

    with right_col:
        st.subheader("🔬 対応評価モデル")
        st.markdown(
            """
            <div style="background:#e8f4fd; border:1px solid #bee3f8;
                        border-radius:10px; padding:1rem 1.2rem; margin-bottom:0.8rem;">
                <div style="font-weight:700; margin-bottom:0.5rem;">📐 Black-Scholes 法</div>
                <ul style="margin:0; padding-left:1.2rem; font-size:0.85rem; color:#444;">
                    <li>解析解による高速計算</li>
                    <li>Delta / Gamma / Theta / Vega / Rho</li>
                    <li>ヨーロピアン・オプション対応</li>
                </ul>
            </div>
            <div style="background:#f0fdf4; border:1px solid #bbf7d0;
                        border-radius:10px; padding:1rem 1.2rem;">
                <div style="font-weight:700; margin-bottom:0.5rem;">🌳 二項モデル（CRR）</div>
                <ul style="margin:0; padding-left:1.2rem; font-size:0.85rem; color:#444;">
                    <li>ヨーロピアン / アメリカン対応</li>
                    <li>早期行使プレミアムを評価</li>
                    <li>ステップ数 200 で高精度</li>
                </ul>
            </div>
            """,
            unsafe_allow_html=True,
        )

    st.divider()
    st.caption(
        "⚖️ Option Valuation System　│　"
        "本システムの評価結果は参考値です。最終的な判断は専門家にご相談ください。"
    )
