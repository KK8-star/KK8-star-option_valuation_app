"""評価一覧ページ - v0.3.1"""
import streamlit as st
from sqlalchemy import select, func, or_
from src.data.database import get_session
from src.data.models import ValuationCase


def _search_cases(keyword: str) -> list[ValuationCase]:
    """キーワードで評価ケースを検索（is_deleted=0のみ）"""
    with get_session() as s:
        base_q = (
            select(ValuationCase)
            .where(ValuationCase.is_deleted == 0)
        )
        if keyword.strip():
            pat = f"%{keyword.strip()}%"
            base_q = base_q.where(
                or_(
                    func.lower(ValuationCase.case_name).like(func.lower(pat)),
                    func.lower(ValuationCase.company_name).like(func.lower(pat)),
                )
            )
        else:
            base_q = base_q.limit(10)

        base_q = base_q.order_by(ValuationCase.created_at.desc())
        rows = s.execute(base_q).all()
        # セッション外で使えるよう属性を辞書化
        result = []
        for r in rows:
            vc = r[0]
            result.append({
                "id": vc.id,
                "case_name": vc.case_name,
                "company_name": vc.company_name,
                "notes": vc.notes,
                "created_at": vc.created_at,
                "updated_at": vc.updated_at,
                "is_deleted": vc.is_deleted,
            })
        return result


def _soft_delete(case_id: int) -> bool:
    """論理削除"""
    try:
        with get_session() as s:
            vc = s.get(ValuationCase, case_id)
            if vc:
                vc.is_deleted = 1
                return True
        return False
    except Exception as e:
        st.error(f"削除エラー: {e}")
        return False


def show():
    st.title("📋 評価一覧")
    st.markdown("---")

    # ── 検索バー ──────────────────────────────────
    col_search, col_btn = st.columns([4, 1])
    with col_search:
        keyword = st.text_input(
            "🔍 ケース名 / 会社名で検索",
            value=st.session_state.get("case_list_keyword", ""),
            placeholder="例: テストケース、サンプル株式会社 …",
            key="case_list_search_input",
        )
    with col_btn:
        st.markdown("<br>", unsafe_allow_html=True)
        if st.button("クリア", use_container_width=True):
            st.session_state["case_list_keyword"] = ""
            st.rerun()

    # キーワードをセッションに保存
    st.session_state["case_list_keyword"] = keyword

    # ── データ取得 ────────────────────────────────
    cases = _search_cases(keyword)

    # ── 件数表示 ──────────────────────────────────
    if keyword.strip():
        st.caption(f"🔎 「{keyword}」の検索結果: **{len(cases)} 件**")
    else:
        st.caption(f"📅 最新 **{len(cases)} 件** を表示（キーワード入力で絞り込み）")

    st.markdown("---")

    # ── 結果表示 ──────────────────────────────────
    if not cases:
        st.info("📭 該当する評価ケースが見つかりません。")
        st.markdown("**ヒント:** 「📊 新規評価」から評価ケースを作成してください。")
        return

    # 削除確認状態管理
    if "delete_confirm_id" not in st.session_state:
        st.session_state["delete_confirm_id"] = None

    for case in cases:
        with st.container(border=True):
            col1, col2, col3 = st.columns([3, 2, 1])

            with col1:
                st.markdown(f"**{case['case_name']}**")
                st.caption(f"🏢 {case['company_name']}")

            with col2:
                created = case["created_at"]
                if created:
                    try:
                        st.caption(f"📅 作成日: {created.strftime('%Y-%m-%d %H:%M')}")
                    except Exception:
                        st.caption(f"📅 作成日: {created}")
                if case["notes"]:
                    st.caption(f"📝 {case['notes'][:40]}{'…' if len(str(case['notes'])) > 40 else ''}")

            with col3:
                btn_key_detail = f"detail_{case['id']}"
                btn_key_delete = f"delete_{case['id']}"

                if st.button("詳細", key=btn_key_detail, use_container_width=True):
                    st.session_state["selected_case_id"] = case["id"]
                    st.session_state["current_page"] = "📊 新規評価"
                    st.rerun()

                # 削除ボタン
                if st.session_state["delete_confirm_id"] == case["id"]:
                    st.warning("本当に削除しますか？")
                    c1, c2 = st.columns(2)
                    with c1:
                        if st.button("✅ はい", key=f"confirm_yes_{case['id']}", use_container_width=True):
                            if _soft_delete(case["id"]):
                                st.success("削除しました")
                                st.session_state["delete_confirm_id"] = None
                                st.rerun()
                    with c2:
                        if st.button("❌ いいえ", key=f"confirm_no_{case['id']}", use_container_width=True):
                            st.session_state["delete_confirm_id"] = None
                            st.rerun()
                else:
                    if st.button("🗑️ 削除", key=btn_key_delete, use_container_width=True):
                        st.session_state["delete_confirm_id"] = case["id"]
                        st.rerun()

    # ── デバッグパネル（折りたたみ） ──────────────
    with st.expander("🔧 デバッグ情報", expanded=False):
        with get_session() as s:
            total = s.execute(select(func.count(ValuationCase.id))).scalar()
            active = s.execute(
                select(func.count(ValuationCase.id)).where(ValuationCase.is_deleted == 0)
            ).scalar()
            deleted = s.execute(
                select(func.count(ValuationCase.id)).where(ValuationCase.is_deleted == 1)
            ).scalar()
        st.write(f"DB総レコード数: {total} | 有効: {active} | 削除済: {deleted}")
        st.write(f"現在のキーワード: 「{keyword}」")
        st.write(f"表示件数: {len(cases)}")


def render():
    show()
