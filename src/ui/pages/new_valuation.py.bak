from __future__ import annotations
import streamlit as st
import numpy as np
import pandas as pd
from datetime import date
from src.services.valuation_service import (
    ValuationService,
    VolatilityMeta,
    ComparableTickerRow,
)


def _fetch_vol(ticker: str, period: str) -> ComparableTickerRow:
    try:
        import yfinance as yf
        hist = yf.Ticker(ticker).history(period=period)
        if hist.empty:
            return ComparableTickerRow(ticker=ticker, fetch_ok=False, error_msg="データなし", vol_period=period)
        log_ret = np.log(hist["Close"] / hist["Close"].shift(1)).dropna()
        vol = float(log_ret.std() * np.sqrt(252))
        try:
            info  = yf.Ticker(ticker).info
            label = info.get("shortName") or info.get("longName") or ticker
        except Exception:
            label = ticker
        return ComparableTickerRow(ticker=ticker, company_label=label, volatility=vol, vol_period=period, fetch_ok=True)
    except Exception as e:
        return ComparableTickerRow(ticker=ticker, fetch_ok=False, error_msg=str(e), vol_period=period)


def _show_comparable_table(rows: list) -> float:
    records = []
    for r in rows:
        records.append({
            "ティッカー": r.ticker,
            "会社名":     r.company_label or r.ticker,
            "σ (年率)":  f"{r.volatility:.4f}" if r.volatility is not None else "取得失敗",
            "期間":       r.vol_period,
            "状態":       "OK" if r.fetch_ok else "NG",
        })
    st.dataframe(pd.DataFrame(records), use_container_width=True, hide_index=True)
    ok_vols = [r.volatility for r in rows if r.fetch_ok and r.volatility is not None]
    if not ok_vols:
        return None
    avg = float(np.mean(ok_vols))
    summary = pd.DataFrame([
        {"指標": "平均 σ",   "値": f"{avg:.4f}"},
        {"指標": "最大 σ",   "値": f"{max(ok_vols):.4f}"},
        {"指標": "最小 σ",   "値": f"{min(ok_vols):.4f}"},
        {"指標": "有効件数", "値": f"{len(ok_vols)} / {len(rows)}"},
    ])
    st.dataframe(summary, use_container_width=True, hide_index=True)
    return avg


def render():
    st.title("新規オプション評価")

    st.subheader("会社情報")
    col1, col2 = st.columns(2)
    with col1:
        company_name = st.text_input("会社名", value="Sample Corp")
        industry = st.selectbox("業種", ["general", "technology", "finance", "energy", "healthcare"])
    with col2:
        currency       = st.selectbox("通貨", ["JPY", "USD", "EUR"])
        valuation_date = st.date_input("評価日", value=date.today())

    st.divider()

    st.subheader("基本パラメータ")
    col3, col4 = st.columns(2)
    with col3:
        stock_price    = st.number_input("株価 (S)",        value=100.0, min_value=0.01, step=1.0)
        strike_price   = st.number_input("行使価格 (K)",    value=100.0, min_value=0.01, step=1.0)
        time_to_expiry = st.number_input("残存期間 (年, T)", value=1.0,   min_value=0.01, step=0.1)
    with col4:
        risk_free_rate = st.number_input("無リスク金利 (r)", value=0.02, min_value=0.0, step=0.001, format="%.3f")
        dividend_yield = st.number_input("配当利回り (q)",   value=0.0,  min_value=0.0, step=0.001, format="%.3f")
        option_type    = st.selectbox("オプション種別", ["call", "put"])

    st.divider()

    st.subheader("ボラティリティ設定")
    col5, col6 = st.columns(2)
    with col5:
        vol_method = st.selectbox("推定方法", ["historical", "implied", "garch", "manual"])
        vol_period = st.selectbox("取得期間", ["1m", "3m", "6m", "1y", "2y", "3y"], index=3)
    with col6:
        vol_source = st.text_input("データソース", value="Yahoo Finance")

    st.divider()

    st.subheader("類似会社ボラティリティ参照")
    st.caption("カンマ区切りでティッカーを入力し「取得」ボタンを押すと平均σが自動反映されます。")

    comp_tickers_raw = st.text_input(
        "類似会社ティッカー（カンマ区切り）",
        value="",
        placeholder="例: 7203.T, 7267.T, 7201.T",
        key="comp_tickers_input",
    )

    comp_rows = []
    fetch_col, _ = st.columns([1, 3])
    with fetch_col:
        do_fetch = st.button("取得", disabled=(not comp_tickers_raw.strip()), key="btn_fetch_tickers")

    if do_fetch and comp_tickers_raw.strip():
        tickers = [t.strip() for t in comp_tickers_raw.split(",") if t.strip()]
        with st.spinner(f"{len(tickers)} 銘柄を取得中..."):
            fetched = [_fetch_vol(t, vol_period) for t in tickers]
        st.session_state["comp_rows"]    = fetched
        st.session_state["comp_vol_avg"] = None

    if "comp_rows" in st.session_state:
        comp_rows = st.session_state["comp_rows"]

    avg_comp_vol = None
    if comp_rows:
        st.markdown("**類似会社 ボラティリティ一覧**")
        avg_comp_vol = _show_comparable_table(comp_rows)
        if avg_comp_vol is not None:
            st.session_state["comp_vol_avg"] = avg_comp_vol
            st.info(f"類似会社平均 σ = {avg_comp_vol:.4f} をボラティリティ入力に反映しています")

    st.divider()

    default_vol = st.session_state.get("comp_vol_avg") or 0.20

    volatility = st.number_input(
        "ボラティリティ (σ)",
        value=float(f"{default_vol:.4f}"),
        min_value=0.001, max_value=5.0, step=0.01, format="%.3f",
    )

    vol_data_raw = st.text_area(
        "ボラティリティ推定メモ（任意）",
        value=(
            f"類似会社: {comp_tickers_raw} / 期間: {vol_period} / 平均σ: {default_vol:.4f}"
            if comp_rows else ""
        ),
        height=80,
    )

    st.divider()

    st.subheader("モデル設定")
    col7, col8 = st.columns(2)
    with col7:
        american = st.checkbox("アメリカンオプション", value=False)
        n_steps  = st.number_input("二項木ステップ数", value=200, min_value=10, max_value=1000, step=10)
    with col8:
        n_paths = st.number_input("モンテカルロ試行数", value=10000, min_value=1000, max_value=100000, step=1000)

    st.divider()

    if st.button("評価実行", type="primary", use_container_width=True):
        with st.spinner("計算中..."):
            try:
                svc    = ValuationService()
                result = svc.calculate(
                    company_name       = company_name,
                    stock_price        = stock_price,
                    strike_price       = strike_price,
                    risk_free_rate     = risk_free_rate,
                    volatility         = volatility,
                    T                  = time_to_expiry,
                    dividend_yield     = dividend_yield,
                    industry           = industry,
                    valuation_date     = valuation_date,
                    currency           = currency,
                    american           = american,
                    n_steps            = int(n_steps),
                    n_paths            = int(n_paths),
                    comparable_tickers = comp_rows,
                )
                vol_meta = VolatilityMeta(
                    vol_method = vol_method,
                    vol_period = vol_period,
                    vol_source = vol_source,
                    vol_data   = vol_data_raw,
                )
                case_id = svc.save(result, option_type=option_type, vol_meta=vol_meta)
                st.success(f"評価完了（ケースID: {case_id}）")
                st.session_state["last_case_id"] = case_id
                st.session_state.pop("comp_rows",    None)
                st.session_state.pop("comp_vol_avg", None)

                st.subheader("評価結果")
                col_r1, col_r2 = st.columns(2)
                with col_r1:
                    st.metric("加重平均コール", f"{result.call_price:,.4f}")
                    st.metric("B-S コール",     f"{result.bs_call:,.4f}")
                    st.metric("二項木 コール",   f"{result.bin_call:,.4f}")
                    st.metric("MC コール",       f"{result.mc_call:,.4f} +/-{result.mc_se:,.4f}")
                with col_r2:
                    st.metric("加重平均プット", f"{result.put_price:,.4f}")
                    st.metric("B-S プット",     f"{result.bs_put:,.4f}")
                    st.metric("二項木 プット",   f"{result.bin_put:,.4f}")
                    st.metric("MC プット",       f"{result.mc_put:,.4f}")

                st.subheader("Greeks")
                gc1, gc2, gc3, gc4, gc5 = st.columns(5)
                gc1.metric("Delta", f"{result.delta_call:.4f}")
                gc2.metric("Gamma", f"{result.gamma:.4f}")
                gc3.metric("Theta", f"{result.theta:.4f}")
                gc4.metric("Vega",  f"{result.vega:.4f}")
                gc5.metric("Rho",   f"{result.rho:.4f}")

                if result.comparable_tickers:
                    st.subheader("類似会社ボラティリティ（保存済み）")
                    _show_comparable_table(result.comparable_tickers)

            except Exception as e:
                st.error(f"計算エラー: {e}")
                import traceback
                st.code(traceback.format_exc())
