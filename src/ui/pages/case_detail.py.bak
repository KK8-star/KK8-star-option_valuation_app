# -*- coding: utf-8 -*-
"""評価結果詳細ページ - DBから保存済みデータを読み込んで表示"""
import streamlit as st
from sqlalchemy import select
from src.data.database import get_session
from src.data.models import ValuationCase, ValuationParameter, ValuationResult

INDUSTRY_LABELS = {
    "tech":          "テクノロジー",
    "finance":       "金融",
    "healthcare":    "ヘルスケア",
    "retail":        "小売",
    "manufacturing": "製造業",
    "other":         "その他",
    "default":       "デフォルト",
}

# model_type → 表示ラベル（DB に保存されている値に合わせる）
MODEL_LABELS = {
    # 加重平均
    "weighted_call":        ("⚖️", "加重平均（コール）"),
    "weighted_put":         ("⚖️", "加重平均（プット）"),
    "weighted":             ("⚖️", "加重平均（総合）"),
    # Black-Scholes
    "black_scholes_call":   ("📐", "ブラック・ショールズ（コール）"),
    "black_scholes_put":    ("📐", "ブラック・ショールズ（プット）"),
    "black_scholes":        ("📐", "ブラック・ショールズ"),
    "bs_call":              ("📐", "ブラック・ショールズ（コール）"),
    "bs_put":               ("📐", "ブラック・ショールズ（プット）"),
    # 二項モデル
    "binomial_call":        ("🌳", "二項モデル CRR（コール）"),
    "binomial_put":         ("🌳", "二項モデル CRR（プット）"),
    "binomial":             ("🌳", "二項モデル CRR"),
    "crr_call":             ("🌳", "二項モデル CRR（コール）"),
    "crr_put":              ("🌳", "二項モデル CRR（プット）"),
    # モンテカルロ
    "monte_carlo_call":     ("🎲", "モンテカルロ（コール）"),
    "monte_carlo_put":      ("🎲", "モンテカルロ（プット）"),
    "monte_carlo":          ("🎲", "モンテカルロ"),
    "mc_call":              ("🎲", "モンテカルロ（コール）"),
    "mc_put":               ("🎲", "モンテカルロ（プット）"),
}

def _model_label(model_type: str) -> str:
    """model_type から表示用文字列を返す（未知の場合はそのまま）"""
    if model_type in MODEL_LABELS:
        icon, name = MODEL_LABELS[model_type]
        return f"{icon} {name}"
    # フォールバック: アンダースコアをスペースに置換して表示
    return f"📊 {model_type.replace('_', ' ').title()}"


def _load_case_data(case_id: int) -> dict | None:
    """DBからケース・パラメータ・結果を一括取得"""
    with get_session() as s:
        case = s.get(ValuationCase, case_id)
        if not case or case.is_deleted:
            return None

        param = s.execute(
            select(ValuationParameter)
            .where(ValuationParameter.case_id == case_id)
            .order_by(ValuationParameter.id.desc())
        ).scalars().first()

        results = s.execute(
            select(ValuationResult)
            .where(ValuationResult.case_id == case_id)
            .order_by(ValuationResult.id.asc())   # 登録順に表示
        ).scalars().all()

        return {
            "case": {
                "id":           case.id,
                "case_name":    case.case_name,
                "company_name": case.company_name,
                "notes":        case.notes,
                "created_at":   case.created_at,
                "updated_at":   case.updated_at,
            },
            "param": {
                "stock_price":    param.stock_price    if param else None,
                "strike_price":   param.strike_price   if param else None,
                "time_to_expiry": param.time_to_expiry if param else None,
                "volatility":     param.volatility     if param else None,
                "risk_free_rate": param.risk_free_rate if param else None,
                "dividend_yield": param.dividend_yield if param else None,
                "option_type":    param.option_type    if param else None,
                "industry":  getattr(param, "industry",       None) if param else None,
                "currency":  getattr(param, "currency",       None) if param else None,
                "valuation_date": getattr(param, "valuation_date", None) if param else None,
            } if param else None,
            "results": [
                {
                    "id":           r.id,
                    "model_type":   r.model_type,
                    "option_value": r.option_value,
                    "delta":        r.delta,
                    "gamma":        r.gamma,
                    "theta":        r.theta,
                    "vega":         r.vega,
                    "rho":          r.rho,
                    "calculated_at": r.calculated_at,
                }
                for r in results
            ],
        }


def _fmt(value, fmt=".4f", suffix="") -> str:
    """数値フォーマット。None/欠損は N/A を返す"""
    if value is None:
        return "N/A"
    try:
        return f"{value:{fmt}}{suffix}"
    except (ValueError, TypeError):
        return str(value)


def render():
    # ── 戻るボタン ──────────────────────────────────────────────
    if st.button("← 評価一覧に戻る", key="back_to_list"):
        st.session_state["current_page"] = "📋 評価一覧"
        st.session_state.pop("selected_case_id", None)
        st.rerun()

    case_id = st.session_state.get("selected_case_id")
    if not case_id:
        st.error("ケースIDが指定されていません。評価一覧から詳細ボタンで開いてください。")
        return

    data = _load_case_data(case_id)
    if data is None:
        st.error(f"ケースID {case_id} のデータが見つかりません（削除済みの可能性があります）")
        return

    case    = data["case"]
    param   = data["param"]
    results = data["results"]

    # ── ヘッダー ────────────────────────────────────────────────
    st.title("📋 評価結果詳細")
    st.markdown(f"### {case['case_name']}")

    col1, col2 = st.columns(2)
    with col1:
        st.caption(f"🏢 会社名: {case['company_name'] or '—'}")
        if case["notes"]:
            st.caption(f"📝 備考: {case['notes']}")
    with col2:
        if case["created_at"]:
            st.caption(f"📅 作成: {case['created_at'].strftime('%Y/%m/%d %H:%M')}")
        if case["updated_at"] and case["updated_at"] != case["created_at"]:
            st.caption(f"🔄 更新: {case['updated_at'].strftime('%Y/%m/%d %H:%M')}")

    st.divider()

    # ── オプションパラメータ ─────────────────────────────────────
    st.subheader("📊 評価パラメータ")
    if param:
        opt_type_label = {"call": "コール (Call)", "put": "プット (Put)"}.get(
            param["option_type"], param["option_type"] or "—"
        )
        col3, col4 = st.columns(2)
        with col3:
            st.metric("株価 / 基準価値 (S)", _fmt(param["stock_price"], ",.2f"))
            st.metric("権利行使価格 (K)",     _fmt(param["strike_price"], ",.2f"))
            st.metric("満期 (T)",             _fmt(param["time_to_expiry"], ".4f", " 年"))
            st.metric("オプション種別",       opt_type_label)
        with col4:
            st.metric("ボラティリティ (σ)",    _fmt(param["volatility"],     ".1%"))
            st.metric("リスクフリーレート (r)", _fmt(param["risk_free_rate"], ".3%"))
            st.metric("配当利回り (q)",         _fmt(param["dividend_yield"], ".3%"))
            if param.get("industry"):
                st.metric("業種", INDUSTRY_LABELS.get(param["industry"], param["industry"]))
            if param.get("currency"):
                st.metric("通貨", param["currency"])
    else:
        st.warning("パラメータデータが見つかりません")

    st.divider()

    # ── 評価結果 ────────────────────────────────────────────────
    st.subheader("💰 評価結果")
    if results:
        # コール / プット でタブを分ける（両方ある場合）
        call_results = [r for r in results if "call" in r["model_type"] or
                        ("call" not in r["model_type"] and "put" not in r["model_type"])]
        put_results  = [r for r in results if "put"  in r["model_type"]]

        if call_results and put_results:
            tab_call, tab_put = st.tabs(["📈 コール (Call)", "📉 プット (Put)"])
            with tab_call:
                _render_results(call_results)
            with tab_put:
                _render_results(put_results)
        else:
            _render_results(results)
    else:
        st.warning("評価結果データが見つかりません")

    st.divider()
    # ── フッター：再度戻るボタン ────────────────────────────────
    if st.button("← 評価一覧に戻る", key="back_to_list_bottom"):
        st.session_state["current_page"] = "📋 評価一覧"
        st.session_state.pop("selected_case_id", None)
        st.rerun()


def _render_results(results: list[dict]):
    """結果リストを横並びメトリクスで描画"""
    for r in results:
        with st.container(border=True):
            label = _model_label(r["model_type"])
            st.markdown(f"**{label}**")
            if r["calculated_at"]:
                st.caption(f"計算日時: {r['calculated_at'].strftime('%Y/%m/%d %H:%M:%S')}")

            # 1行目: オプション価値 + Greeks
            c1, c2, c3, c4, c5, c6 = st.columns(6)
            c1.metric("オプション価値", _fmt(r["option_value"], ",.4f"))
            c2.metric("Δ デルタ",       _fmt(r["delta"],        ".4f"))
            c3.metric("Γ ガンマ",       _fmt(r["gamma"],        ".6f"))
            c4.metric("ν ベガ",         _fmt(r["vega"],         ".4f"))
            c5.metric("Θ シータ",       _fmt(r["theta"],        ".4f"))
            c6.metric("ρ ロー",         _fmt(r["rho"],          ".4f"))
